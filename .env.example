PORT=3000

# =====================================
# PostgreSQL — استخدم رابط Neon.tech في الإنتاج
# =====================================
# محلياً (localhost):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ramadan_baskets
#
# من Neon.tech (الإنتاج):
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/ramadan_baskets?sslmode=require

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# SMS (Twilio) — اختياري
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Upload directory
UPLOAD_DIR=./uploads
